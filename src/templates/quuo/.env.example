# Credenciales de Bitbucket — necesarias para instalar repos base de Quuo
REPO_USER=tu_usuario_bitbucket
REPO_PASS=tu_app_password_o_token

# Secretos AWS (nombres en Secrets Manager)
SECRET_ROOT=nombre-del-secreto-root
SECRET_CORE=nombre-del-secreto-core

# WAF
WAF_NAME=nombre-del-waf
WAF_VERSION=Regional

# Company para desarrollo local
SECRET_ID_COMPANY=codigo-company-local

# Variables propias del repo
# MAIL_URL=https://api.mail.net/
